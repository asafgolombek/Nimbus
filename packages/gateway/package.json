{
  "name": "@nimbus/gateway",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run compile-gateway.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "bun test",
    "clean": "rm -rf dist",
    "test:coverage:updater": "bun test --coverage src/updater",
    "test:coverage:lan": "bun test --coverage src/ipc/lan-crypto.test.ts src/ipc/lan-pairing.test.ts src/ipc/lan-rate-limit.test.ts src/ipc/lan-rpc.test.ts src/ipc/lan-server.test.ts"
  },
  "dependencies": {
    "@nimbus-dev/sdk": "workspace:*",
    "@mastra/core": "^1.25.0",
    "@mastra/mcp": "^1.5.1",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@xenova/transformers": "^2.17.0",
    "bs58": "^6.0.0",
    "pino": "^10.3.1",
    "sqlite-vec": "^0.1.6",
    "tar": "^7.4.3",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/tar": "^7.0.87"
  }
}
