{
  "name": "@nimbus/cli",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "nimbus": "./dist/nimbus"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --compile --outfile dist/nimbus",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@nimbus-dev/client": "workspace:*",
    "@nimbus-dev/sdk": "workspace:*",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1"
  }
}
