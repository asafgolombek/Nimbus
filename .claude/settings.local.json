{
  "permissions": {
    "allow": [
      "Bash(bun install:*)",
      "Bash(bun pm:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(bun audit:*)",
      "Bash(bunx:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(curl -fsSL -H \"Accept: application/vnd.github+json\" \"https://api.github.com/repos/step-security/harden-runner/git/ref/tags/v2.18.0\")",
      "Bash(sed -i 's|actions/cache@v4.2.0|actions/cache@1bd1e32a3bdc45362d1e726936510720a7c30a57 # v4.2.0|g' .github/workflows/ci.yml .github/workflows/security.yml)",
      "Bash(sed -i 's|oven-sh/setup-bun@v2.0.1|oven-sh/setup-bun@4bc047ad259df6fc24a6c9b0f9a0cb08cf17fbe5 # v2.0.1|g' .github/actions/setup-nimbus-ci/action.yml)",
      "Bash(git stash *)",
      "Bash(echo \"EXIT_CODE=$?\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const p=j.tool_input?.file_path||'';if(/\\.(ts|tsx|js|jsx|json)$/i.test(p)){console.log(p)}})\"); [ -n \"$f\" ] && bunx biome check --write \"$f\" 2>/dev/null; true",
            "statusMessage": "Biome: formatting and linting..."
          },
          {
            "type": "command",
            "command": "f=$(node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);const p=j.tool_input?.file_path||'';if(/\\.(ts|tsx)$/i.test(p)){console.log(p)}})\"); [ -n \"$f\" ] && bun run typecheck || true",
            "statusMessage": "TypeScript: type checking...",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
