{
  "name": "nimbus",
  "version": "0.0.0",
  "private": true,
  "overrides": {
    "sharp": "0.34.5"
  },
  "workspaces": [
    "packages/gateway",
    "packages/cli",
    "packages/ui",
    "packages/sdk",
    "packages/client",
    "packages/docs",
    "packages/mcp-connectors/onedrive",
    "packages/mcp-connectors/outlook",
    "packages/mcp-connectors/google-photos",
    "packages/mcp-connectors/google-drive",
    "packages/mcp-connectors/gmail",
    "packages/mcp-connectors/github",
    "packages/mcp-connectors/gitlab",
    "packages/mcp-connectors/bitbucket",
    "packages/mcp-connectors/slack",
    "packages/mcp-connectors/teams",
    "packages/mcp-connectors/linear",
    "packages/mcp-connectors/jira",
    "packages/mcp-connectors/notion",
    "packages/mcp-connectors/confluence",
    "packages/mcp-connectors/discord",
    "packages/mcp-connectors/jenkins",
    "packages/mcp-connectors/github-actions",
    "packages/mcp-connectors/circleci",
    "packages/mcp-connectors/pagerduty",
    "packages/mcp-connectors/kubernetes",
    "packages/mcp-connectors/aws",
    "packages/mcp-connectors/azure",
    "packages/mcp-connectors/gcp",
    "packages/mcp-connectors/iac",
    "packages/mcp-connectors/grafana",
    "packages/mcp-connectors/sentry",
    "packages/mcp-connectors/newrelic",
    "packages/mcp-connectors/datadog"
  ],
  "scripts": {
    "dev": "bun run --filter './packages/gateway' dev & bun run --filter './packages/cli' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test packages/gateway packages/cli packages/sdk packages/client",
    "test:ci": "bun scripts/run-tests.ts",
    "kill-gateway": "bun scripts/kill-gateway.ts",
    "test:unit": "bun test packages/gateway/src packages/cli/src packages/sdk/src",
    "test:integration": "bun test packages/gateway/test/integration/ packages/cli/test/integration/",
    "test:e2e:cli": "bun test packages/cli/test/e2e/",
    "test:e2e:gateway": "bun test packages/gateway/test/e2e/",
    "test:coverage": "bun test packages/gateway packages/cli packages/sdk --coverage",
    "test:coverage:engine": "bun test packages/gateway/src/engine --coverage --coverage-threshold-lines=85",
    "test:coverage:vault": "bun test packages/gateway/src/vault --coverage --coverage-threshold-lines=90",
    "test:coverage:sync": "bun test packages/gateway/src/sync/scheduler.test.ts --coverage --coverage-threshold-lines=80",
    "test:coverage:rate-limiter": "bun test packages/gateway/src/sync/rate-limiter.test.ts --coverage --coverage-threshold-lines=85",
    "test:coverage:people": "bun test packages/gateway/src/people --coverage --coverage-threshold-lines=80",
    "test:coverage:embedding": "bun test packages/gateway/src/embedding --coverage --coverage-threshold-lines=80",
    "test:coverage:workflow": "bun test packages/gateway/src/automation/workflow-store.test.ts packages/gateway/src/automation/workflow-runner.test.ts packages/gateway/src/automation/workflow-runner-execution.test.ts --coverage --coverage-threshold-lines=80",
    "test:coverage:watcher": "bun test packages/gateway/src/automation/watcher-store.test.ts packages/gateway/src/automation/watcher-engine.test.ts packages/gateway/src/watcher/anomaly-detector.test.ts --coverage --coverage-threshold-lines=80",
    "test:coverage:extensions": "bun test packages/gateway/src/extensions/install-from-local.test.ts packages/gateway/src/extensions/manifest.test.ts packages/gateway/src/extensions/spawn-env.test.ts packages/gateway/src/extensions/verify-extensions.test.ts packages/gateway/src/automation/extension-store.test.ts --coverage --coverage-threshold-lines=85",
    "test:coverage:config": "bun test packages/gateway/src/config --coverage --coverage-threshold-lines=80",
    "test:coverage:client": "bun test packages/client --coverage --coverage-threshold-lines=80",
    "test:coverage:telemetry": "bun test packages/gateway/src/config/telemetry-toml.test.ts packages/gateway/test/unit/telemetry --coverage --coverage-threshold-lines=85",
    "docs:build": "bun run --filter @nimbus/docs build",
    "package:headless": "bun scripts/package-headless-bundle.ts",
    "package:installers:linux": "bun scripts/package-linux-installers.ts",
    "clean": "bun run --filter '*' clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "typescript": "^6.0.2"
  }
}
