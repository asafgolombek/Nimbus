# ============================================================
# Nimbus — .gitignore
# Bun / Node / TypeScript / OS / Tauri / Rust artifacts
# ============================================================

# --- Bun / Node ---
node_modules/
.bun-cache/
*.bun

# --- Build outputs ---
dist/
build/
out/
.astro/

# Bundled JS must not live under package src/ (use dist/ or repo root dist/ via scripts/build-debug.ts)
packages/cli/src/nimbus.js
packages/cli/src/nimbus.js.map
packages/gateway/src/nimbus-gateway.js
packages/gateway/src/nimbus-gateway.js.map
packages/mcp-connectors/*/src/nimbus-mcp-*.js
packages/mcp-connectors/*/src/nimbus-mcp-*.js.map
.turbo/

# --- TypeScript ---
*.tsbuildinfo
*.d.ts.map

# --- Coverage / CI test reports ---
coverage/
# JUnit XML for CI lives under junit-reports/ (not ignored — dorny/test-reporter uses fast-glob with gitignore).
reports/
.nyc_output/
lcov.info
*.lcov

# --- Logs ---
*.log
logs/
pino-*.log

# --- Environment & secrets (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.cert
*.cer
nimbus.toml

# --- OS ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- Editors ---
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-*

# --- Tauri / Rust ---
src-tauri/target/
src-tauri/WixTools/
*.dmg
*.deb
*.AppImage
*.app/
gen/

# --- Tauri WebView caches ---
.webview2/
WebView2Loader.dll

# --- SQLite (runtime databases) ---
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# --- Test artifacts ---
test-results/
playwright-report/
blob-report/
playwright/.cache/
*.snap

# --- Git worktrees ---
.worktrees/

# --- Superpowers brainstorming artifacts ---
.superpowers/

# --- Release binaries ---
nimbus-*.exe
nimbus-*.dmg
nimbus-*.deb
nimbus-*.AppImage
nimbus

# Git worktrees
.worktrees/
