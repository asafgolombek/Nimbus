{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "ignore": ["**/*.test.ts"]
    },
    "packages/gateway": {
      "entry": [
        "src/index.ts",
        "src/perf/surfaces/sqlite-worker-sync.ts",
        "src/perf/surfaces/sqlite-worker-watcher.ts",
        "src/perf/surfaces/sqlite-worker-audit.ts",
        "src/**/*.test.ts",
        "test/**/*.test.ts"
      ],
      "project": "src/**/*.ts"
    },
    "packages/cli": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/ui": {
      "entry": ["src/**/*.test.{ts,tsx}", "test/**/*.test.{ts,tsx}"],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/sdk": {
      "entry": ["src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/client": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "test/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/mcp-connectors/*": {
      "entry": ["src/server.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    }
  },
  "ignoreDependencies": [],
  "ignoreBinaries": []
}
