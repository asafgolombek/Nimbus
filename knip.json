{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.ts"],
      "ignore": ["**/*.test.ts"]
    },
    "packages/gateway": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/cli": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/ui": {
      "entry": ["src/main.tsx", "src/**/*.test.{ts,tsx}", "src/**/*.vitest.tsx"],
      "project": "src/**/*.{ts,tsx}"
    },
    "packages/sdk": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/client": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "packages/mcp-connectors/*": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    }
  },
  "ignoreDependencies": [],
  "ignoreBinaries": []
}
